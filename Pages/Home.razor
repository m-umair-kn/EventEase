@page "/"

<h1>EventEase - Event Management</h1>

<div class="container">
    <h2>Upcoming Events</h2>
    <p>Browse our collection of upcoming events and register for those that interest you.</p>

    @if (events == null)
    {
        <div class="loading-spinner">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading events...</p>
        </div>
    }
    else if (events.Count == 0)
    {
        <div class="alert alert-info">No events available at this time.</div>
    }
    else
    {
        <div class="row">
            @foreach (var evt in events)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <h5>@evt.Name</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Date:</strong> @evt.Date.ToString("MMM dd, yyyy")</p>
                            <p><strong>Location:</strong> @evt.Location</p>
                            <p>
                                <span class="@(evt.IsRegistrationOpen ? "text-success" : "text-danger")">
                                    @evt.CurrentAttendees/@evt.MaxAttendees spots filled
                                </span>
                            </p>
                        </div>
                        <div class="card-footer">
                            <button class="btn btn-primary" @onclick="() => NavigateToDetails(evt.Id)">
                                View Details
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    // Injecting services
    [Inject]
    private EventService EventService { get; set; } = default!;
    
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;
    
    private List<Event>? events;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetEventsAsync();
    }

    private void NavigateToDetails(int eventId)
    {
        NavigationManager.NavigateTo($"/event/{eventId}");
    }
}
}
